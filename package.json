{
  "name": "@tiwz/react-video-player",
  "version": "2.1.0",
  "description": "A modern, mobile-friendly React video player with HLS streaming, multi-quality switching, subtitles, Picture-in-Picture, fullscreen, and custom controls",
  "author": "tiwz",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "react",
    "video",
    "video-player",
    "react-video-player",
    "hls",
    "hls-player",
    "m3u8",
    "subtitles",
    "captions",
    "webvtt",
    "picture-in-picture",
    "pip",
    "fullscreen",
    "multi-quality",
    "adaptive-streaming",
    "mobile",
    "touch",
    "double-tap",
    "keyboard-shortcuts",
    "custom-controls",
    "typescript",
    "react-component",
    "media-player",
    "streaming"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TiwPhiraphan/react-video-player.git"
  },
  "homepage": "https://github.com/TiwPhiraphan/react-video-player#readme",
  "bugs": {
    "url": "https://github.com/TiwPhiraphan/react-video-player/issues"
  },
  "style": "dist/VideoPlayer.css",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/VideoPlayer.d.ts",
      "import": "./dist/VideoPlayer.mjs",
      "require": "./dist/VideoPlayer.js"
    },
    "./style.css": {
      "default": "./dist/VideoPlayer.css"
    }
  },
  "scripts": {
    "export": "rollup -c --bundleConfigAsCjs",
    "lint": "biome format --write && biome check"
  },
  "peerDependencies": {
    "react": ">=19"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/hls.js": "^1.0.0",
    "@types/node": "^25.0.10",
    "@types/react": "^19.2.9",
    "autoprefixer": "^10.4.23",
    "hls.js": "^1.6.15",
    "postcss": "^8.5.6",
    "postcss-url": "^10.1.3",
    "rollup": "^4.57.0",
    "rollup-plugin-dts": "^6.3.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  }
}
